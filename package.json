{
  "name": "llm-daily-review",
  "version": "1.0.0",
  "description": "Automated daily discovery and evaluation of LLM apps from Hacker News",
  "type": "module",
  "license": "CC-BY-4.0",
  "homepage": "https://tokenstree.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokenstree/llm-daily-review"
  },
  "scripts": {
    "start": "node --env-file=.env src/web/server.js",
    "review": "node --env-file=.env src/orchestrator/run.js",
    "dev": "node --watch src/web/server.js",
    "test": "node --test src/**/*.test.js",
    "setup-cron": "bash cron/setup-cron.sh"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0",
    "express": "^4.18.3",
    "nodemailer": "^6.9.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}